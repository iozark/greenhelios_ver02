generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  passwordHash         String
  firstName            String   @default("Alex")
  lastName             String   @default("Morgan")
  role                 String   @default("USER")
  enabled              Boolean  @default(true)
  currency             String   @default("EUR")
  language             String   @default("English (US)")
  timezone             String   @default("UTC")
  dateFormat           String   @default("DD/MM/YYYY")
  emailProductUpdates  Boolean  @default(true)
  emailSecurityAlerts  Boolean  @default(false)
  emailBillingReports  Boolean  @default(true)
  emailTaskReminders   Boolean  @default(false)
  pushDirectMessages   Boolean  @default(true)
  pushMentions         Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  properties    Property[]
  notifications Notification[]
}

model Property {
  id          String   @id @default(cuid())
  title       String
  location    String
  category    String   @default("Residential")
  area        String   @default("85 m²")
  status      String   @default("Vacant")
  revenue     Float    @default(0)
  energyClass String   @default("A")
  bedrooms    Int      @default(1)
  bathrooms   Int      @default(1)
  occupants   Int      @default(2)
  imageClass  String   @default("")
  dateFrom    String?
  dateTo      String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes  Income[]
  expenses Expense[]

  @@index([userId])
}

model Income {
  id          String   @id @default(cuid())
  amount      Float
  date        String
  description String   @default("Income")
  propertyId  String
  createdAt   DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([date])
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  amount      Float
  date        String
  description String   @default("Expense")
  propertyId  String
  createdAt   DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([date])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  iconClass String   @default("bg-blue-500")
  iconSymbol String  @default("📋")
  createdAt DateTime @default(now())
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
